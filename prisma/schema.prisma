generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Artwork {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  description String?
  imageUrl    String
  category    String
  tags        String[]
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AIImage {
  id        String   @id @default(cuid())
  prompt    String
  imageUrl  String
  style     String?
  createdAt DateTime @default(now())
}

model Order {
  id          String   @id @default(cuid())
  name        String
  email       String
  description String
  imageUrl    String?
  budget      String?
  dimensions  String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}